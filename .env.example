# ══════════════════════════════════════════════════════════════
# .ENV.EXAMPLE — Plantilla de configuración
# Copiar como .env y completar con los valores reales.
# NUNCA subir .env al repositorio.
# ══════════════════════════════════════════════════════════════

# ── Power BI Service (Azure AD Service Principal) ─────────────
PBI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_CLIENT_SECRET=xxxxxx~xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PBI_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Reporte Power BI a capturar ────────────────────────────────
PBI_REPORT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_PAGE_ID=xxxxxxxxxxxxxxxxxxxx
PBI_PAGE_NAME=ZONAL_SUPERVISOR
# URL completa del reporte (usada en arranque_chrome.bat)
PBI_REPORT_URL=https://app.powerbi.com/groups/<WORKSPACE_ID>/reports/<REPORT_ID>/<PAGE_ID>

# ── SQL Server ─────────────────────────────────────────────────
SQL_SERVER=SERVIDOR\INSTANCIA
SQL_DATABASE=NombreBaseDeDatos
SQL_USER=usuario_sql
SQL_PASSWORD=

# ── OneDrive / datalake ────────────────────────────────────────
# Ruta completa a la carpeta de destino (si no se define, se auto-detecta)
# ONEDRIVE_PATH=C:\Users\TuUsuario\OneDrive - empresa\datalake_processed
# Subcarpeta a buscar en OneDrive cuando se auto-detecta (sin ruta completa)
ONEDRIVE_ORG_FOLDER=datalake_processed_auren

# ── Google Sheets: tabla RH publicada como CSV ────────────────
RH_SHEETS_URL=https://docs.google.com/spreadsheets/d/e/XXXXX/pub?gid=XXXXX&single=true&output=csv

# ── Gmail trigger ─────────────────────────────────────────────
GMAIL_REMITENTE=remitente@empresa.com
GMAIL_ASUNTO=Asunto exacto del correo trigger

# ── WhatsApp ──────────────────────────────────────────────────
WA_GRUPO=Nombre del grupo de WhatsApp
WA_PORT=8002
WA_SERVER_PATH=C:\ruta\al\whatsapp_server
WA_CONFIG_PATH=C:\ruta\al\whatsapp_server\config.json

# ── Chrome (auto-detectado en rutas estándar si no se define) ─
# CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_USER_DIR=C:\chrome_pbi_session

# ── Directorio de capturas (default: capturas/ relativo al proyecto) ─
# SCREENSHOT_DIR=C:\proyectos\Dash_consultas_pbi\capturas

# ── Proxy corporativo (opcional, dejar vacío si no aplica) ────
# HTTPS_PROXY=http://proxy.empresa.com:8080
# PROXY_USER=usuario
# PROXY_PASS=contraseña
