# ══════════════════════════════════════════════════════════════
# .ENV.EXAMPLE — Plantilla de configuración
# Copiar como .env y completar con los valores reales.
# NUNCA subir .env al repositorio.
# ══════════════════════════════════════════════════════════════

# ── Power BI Service (Azure AD Service Principal) ─────────────
PBI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_CLIENT_SECRET=xxxxxx~xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PBI_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── SQL Server ─────────────────────────────────────────────────
# Si no se define, usa la autenticación de Windows (Trusted_Connection)
SQL_SERVER=AUREN22\AUREN
SQL_DATABASE=eAuren
SQL_USER=eauren
SQL_PASSWORD=

# ── OneDrive (auto-detectado si no se define) ─────────────────
# ONEDRIVE_PATH=C:\Users\TuUsuario\OneDrive - grupoauren.pe\datalake_processed_auren

# ── Chrome (auto-detectado en rutas estándar si no se define) ─
# CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe

# ── Directorio de capturas (default: capturas/ relativo al proyecto) ─
# SCREENSHOT_DIR=C:\proyectos\Dash_consultas_pbi\capturas

# ── Proxy corporativo (opcional, dejar vacío si no aplica) ────
# HTTPS_PROXY=http://proxy.empresa.com:8080
# PROXY_USER=usuario
# PROXY_PASS=contraseña
